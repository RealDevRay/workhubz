# ============================================
# WorkHubz Hub Ingestion Pipeline - Environment
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.
# ============================================

# Search API - SerpAPI recommended (https://serpapi.com)
# The pipeline uses SerpAPI for Google-like search results (BingSearchClient class name is legacy)
SERPAPI_API_KEY=your_serpapi_key_here

# Firecrawl (provided by user)
FIRECRAWL_API_KEY=fc-fc2c3f2f71694db2aa95313d5fc917e6

# Groq (for LLM extraction)
GROQ_API_KEY=your_groq_key_here

# Supabase - USE SERVICE ROLE for this pipeline (writes)
SUPABASE_URL=https://srrqhcltnhxdkkeqdsxh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: Model to use on Groq
GROQ_MODEL=llama-3.1-70b-versatile
# Alternative: meta-llama/llama-4-maverick-17b-128e-instruct (or whatever Llama 4 name is current)